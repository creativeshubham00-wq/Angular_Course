/* To learn more about this file see: https://angular.io/config/tsconfig. */
/*This file contains configuration to run test files .spec.ts, d.ts*/
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": [
      "jasmine"
    ]
  },
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
